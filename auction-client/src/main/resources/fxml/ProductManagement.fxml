<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<HBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.auction.ui.view.ProductManagementController"
      prefWidth="1040" prefHeight="660"
      style="-fx-background-color: #f3f6fb;">

    <VBox prefWidth="250"
          spacing="22"
          style="-fx-background-color: #172033;">
        <padding>
            <Insets top="28" right="18" bottom="24" left="18"/>
        </padding>

        <VBox spacing="2">
            <Label text="ĐẤU GIÁ"
                   style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #8fb2ff;"/>
            <Label text="Bảng điều khiển"
                   style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: white;"/>
        </VBox>

        <VBox spacing="8">
            <Button text="Phiên đấu giá"
                    onAction="#handleCurrentAuctions"
                    maxWidth="Infinity"
                    alignment="CENTER_LEFT"
                    styleClass="sidebar-button">
                <graphic>
                    <Region styleClass="icon-style, icon-auction"/>
                </graphic>
            </Button>

            <Button fx:id="productsSidebarButton"
                    text="Kho hàng"
                    onAction="#handleSidebarProducts"
                    maxWidth="Infinity"
                    alignment="CENTER_LEFT"
                    styleClass="sidebar-button, active-tab">
                <graphic>
                    <Region styleClass="icon-style, icon-warehouse"/>
                </graphic>
            </Button>

            <Button fx:id="bidHistorySidebarButton"
                    text="Lịch sử đặt giá"
                    onAction="#handleSidebarBidHistory"
                    maxWidth="Infinity"
                    alignment="CENTER_LEFT"
                    styleClass="sidebar-button">
                <graphic>
                    <Region styleClass="icon-style, icon-history"/>
                </graphic>
            </Button>

            <Button text="Tài khoản"
                    onAction="#handleSidebarAccount"
                    maxWidth="Infinity"
                    alignment="CENTER_LEFT"
                    styleClass="sidebar-button">
                <graphic>
                    <Region styleClass="icon-style, icon-account"/>
                </graphic>
            </Button>
        </VBox>

        <Region VBox.vgrow="ALWAYS"/>

        <VBox spacing="10">
            <VBox spacing="6"
                  style="-fx-background-color: #22304a; -fx-background-radius: 8; -fx-padding: 14;">
                <Label text="Tài khoản"
                       style="-fx-font-size: 12px; -fx-text-fill: #9aa8bd;"/>

                <Label fx:id="accountRoleLabel"
                       text="Role: "
                       style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: white;"/>

                <Label fx:id="accountBalanceLabel"
                       text="Đang tải..."
                       style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: white;"/>
            </VBox>
        </VBox>
    </VBox>

    <VBox spacing="18" HBox.hgrow="ALWAYS">
        <padding><Insets top="28" right="34" bottom="28" left="34"/></padding>

        <HBox alignment="CENTER_LEFT">
            <VBox spacing="4">
                <Label fx:id="titleLabel" style="-fx-font-size: 30px; -fx-font-weight: bold; -fx-text-fill: #172033;"/>
                <Label fx:id="subtitleLabel" style="-fx-font-size: 13px; -fx-text-fill: #667085;"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="+ Đăng sản phẩm" onAction="#handleAddProduct"
                    styleClass="primary-action-button"/>
        </HBox>

        <VBox VBox.vgrow="ALWAYS"
              style="-fx-background-color: white; -fx-background-radius: 10; -fx-border-color: #e0e7f0; -fx-border-radius: 10; -fx-padding: 18;">

            <TableView fx:id="myProductsTable" VBox.vgrow="ALWAYS"
                       styleClass="auction-table">
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                </columnResizePolicy>

                <placeholder>
                    <VBox alignment="CENTER" spacing="14" style="-fx-padding: 40 0;">
                        <Region styleClass="icon-style, icon-warehouse" style="-fx-pref-width: 54px; -fx-pref-height: 54px; -fx-background-color: #98a2b3;"/>
                        <VBox alignment="CENTER" spacing="4">
                            <Label text="Kho hàng của bạn hiện đang trống" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #344054;"/>
                            <Label text="Hãy nhấn nút '+ Đăng sản phẩm' ở góc trên bên phải để tạo phiên đấu giá đầu tiên." style="-fx-font-size: 13px; -fx-text-fill: #667085;"/>
                        </VBox>
                    </VBox>
                </placeholder>
            </TableView>
        </VBox>

        <HBox spacing="12" alignment="CENTER_RIGHT">
            <Button text="Xem chi tiết" onAction="#handleViewDetail" prefWidth="140"
                    styleClass="auction-filter-button"/>
            <Button text="Theo dõi" onAction="#handleMonitorAuction" prefWidth="140"
                    styleClass="auction-filter-button"/>
            <Button text="Chỉnh sửa" onAction="#handleEditAuctionFull" prefWidth="140"
                    styleClass="auction-filter-button"/>
            <Button text="Xóa sản phẩm" onAction="#handleDeleteProduct" prefWidth="140"
                    styleClass="danger-action-button"/>
        </HBox>
    </VBox>
</HBox>
