<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<HBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.auction.client.controller.ProductManagementController"
      prefWidth="1040" prefHeight="660"
      style="-fx-background-color: #f3f6fb;">

    <VBox prefWidth="230" spacing="22" style="-fx-background-color: #172033;">
        <padding><Insets top="28" right="18" bottom="24" left="18"/></padding>
        <VBox spacing="2">
            <Label text="CÁ NHÂN" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #8fb2ff;"/>
            <Label text="Kho hàng" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: white;"/>
        </VBox>
        <VBox spacing="8">
            <Button fx:id="backButton"
                    text="← Quay lại"
                    onAction="#handleBack"
                    maxWidth="Infinity"
                    alignment="CENTER_LEFT"
                    focusTraversable="false" />
        </VBox>
        <Region VBox.vgrow="ALWAYS"/>
    </VBox>

    <VBox spacing="18" HBox.hgrow="ALWAYS">
        <padding><Insets top="28" right="34" bottom="28" left="34"/></padding>

        <HBox alignment="CENTER_LEFT">
            <VBox spacing="4">
                <Label fx:id="titleLabel" style="-fx-font-size: 30px; -fx-font-weight: bold; -fx-text-fill: #172033;"/>
                <Label fx:id="subtitleLabel" style="-fx-font-size: 13px; -fx-text-fill: #667085;"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="+ Đăng sản phẩm" onAction="#handleAddProduct"
                    style="-fx-background-color: #2d6cdf; -fx-background-radius: 6; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 11 20;"/>
        </HBox>

        <VBox VBox.vgrow="ALWAYS"
              style="-fx-background-color: white; -fx-background-radius: 10; -fx-border-color: #e0e7f0; -fx-border-radius: 10; -fx-padding: 18;">

            <TableView fx:id="myProductsTable" VBox.vgrow="ALWAYS"
                       style="-fx-background-color: white; -fx-border-color: #e4e7ec; -fx-border-radius: 6; -fx-background-radius: 6;">
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                </columnResizePolicy>
            </TableView>
        </VBox>

        <HBox spacing="12" alignment="CENTER_RIGHT">
            <Button text="Chỉnh sửa" onAction="#handleEditProduct" prefWidth="140"
                    style="-fx-background-color: white; -fx-border-color: #b8c2d6; -fx-border-radius: 6; -fx-text-fill: #344054; -fx-font-weight: bold; -fx-padding: 11 14;"/>
            <Button text="Xóa sản phẩm" onAction="#handleDeleteProduct" prefWidth="140"
                    style="-fx-background-color: #fff1f0; -fx-border-color: #ffa39e; -fx-border-radius: 6; -fx-text-fill: #cf1322; -fx-font-weight: bold; -fx-padding: 11 14;"/>
        </HBox>
    </VBox>
</HBox>