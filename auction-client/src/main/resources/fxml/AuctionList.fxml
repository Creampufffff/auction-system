<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="20" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.auction.client.controller.AuctionListController"
      style="-fx-padding: 30;">

    <HBox alignment="CENTER_LEFT" spacing="20">
        <Label text="Current Auctions" styleClass="title-label"/>
        <Region HBox.hgrow="ALWAYS" /> <!-- Pushes next element to the right -->
        <TextField promptText="Search products..." prefWidth="250"/>
    </HBox>

    <TableView fx:id="auctionTable" VBox.vgrow="ALWAYS">
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>
    </TableView>

    <HBox spacing="15" alignment="CENTER_RIGHT">
        <Button text="View Details" style="-fx-background-color: #94e2d5;"/>
        <Button text="Join Bidding" />
    </HBox>
</VBox>