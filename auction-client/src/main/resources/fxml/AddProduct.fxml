<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.auction.ui.view.AddProductController"
            fitToWidth="true"
            hbarPolicy="NEVER"
            vbarPolicy="AS_NEEDED"
            styleClass="product-dialog-scroll">
    <VBox styleClass="product-dialog-shell">
        <HBox spacing="16" styleClass="product-dialog-custom-header">
            <Label text="+" styleClass="product-dialog-header-icon"/>
            <VBox spacing="4">
                <Label text="Đăng sản phẩm mới" styleClass="product-dialog-title"/>
                <Label text="Điền thông tin chi tiết để tạo phiên đấu giá" styleClass="product-dialog-subtitle"/>
            </VBox>
        </HBox>

        <VBox spacing="16" styleClass="product-dialog-body">
            <VBox spacing="16">
                <HBox spacing="10" styleClass="product-dialog-section-title-row">
                    <Label text="i" styleClass="product-dialog-section-icon"/>
                    <Label text="Thông tin cơ bản" styleClass="product-dialog-section-title"/>
                </HBox>

                <HBox spacing="28">
                    <VBox spacing="12" prefWidth="540">
                        <VBox spacing="7" styleClass="product-dialog-field">
                            <Label text="Tên sản phẩm *" styleClass="product-dialog-field-label"/>
                            <TextField fx:id="nameField" promptText="Nhập tên sản phẩm" styleClass="product-dialog-input"/>
                        </VBox>

                        <VBox spacing="7" styleClass="product-dialog-field">
                            <Label text="Loại auction *" styleClass="product-dialog-field-label"/>
                            <ComboBox fx:id="auctionTypeBox" maxWidth="Infinity" styleClass="product-dialog-input"/>
                        </VBox>

                        <VBox spacing="7" styleClass="product-dialog-field">
                            <Label text="Giá khởi điểm ($) *" styleClass="product-dialog-field-label"/>
                            <TextField fx:id="priceField" promptText="Nhập giá khởi điểm" styleClass="product-dialog-input"/>
                        </VBox>

                        <VBox spacing="7" styleClass="product-dialog-field">
                            <Label fx:id="conditionLabel" text="Tác giả:" styleClass="product-dialog-field-label"/>
                            <TextField fx:id="conditionField" promptText="Nhập tên tác giả (nếu có)" styleClass="product-dialog-input"/>
                        </VBox>
                    </VBox>

                    <VBox fx:id="imageBox"
                          alignment="CENTER"
                          spacing="10"
                          onMouseClicked="#handleChooseImage"
                          styleClass="product-dialog-upload-box">
                        <Label text="IMG" styleClass="product-dialog-upload-icon"/>
                        <Label fx:id="imageUploadTitle" text="Thêm ảnh sản phẩm" styleClass="product-dialog-upload-title"/>
                        <Label fx:id="imageUploadHelp" text="Nhấn để chọn" styleClass="product-dialog-upload-help"/>
                        <Label text="JPG, PNG (tối đa 5MB)" styleClass="product-dialog-upload-note"/>
                    </VBox>
                </HBox>

                <VBox spacing="7" styleClass="product-dialog-field">
                    <Label text="Mô tả chi tiết" styleClass="product-dialog-field-label"/>
                    <TextArea fx:id="descriptionArea"
                              prefRowCount="2"
                              promptText="Nhập mô tả chi tiết về sản phẩm..."
                              styleClass="product-dialog-input"/>
                </VBox>

                <VBox fx:id="typeSpecificBox" spacing="7" styleClass="product-dialog-field">
                    <Label fx:id="warrantyLabel" text="Thông tin phụ:" styleClass="product-dialog-field-label"/>
                    <TextField fx:id="warrantyField" promptText="Có thể bỏ trống" styleClass="product-dialog-input"/>
                </VBox>
            </VBox>

            <VBox spacing="14" styleClass="product-dialog-section">
                <HBox spacing="10" styleClass="product-dialog-section-title-row">
                    <Label text="T" styleClass="product-dialog-section-icon"/>
                    <Label text="Thời gian đấu giá" styleClass="product-dialog-section-title"/>
                </HBox>

                <GridPane hgap="28" vgap="12">
                    <columnConstraints>
                        <ColumnConstraints hgrow="ALWAYS"/>
                        <ColumnConstraints hgrow="ALWAYS"/>
                    </columnConstraints>

                    <VBox spacing="7" styleClass="product-dialog-field" GridPane.rowIndex="0" GridPane.columnIndex="0">
                        <Label text="Ngày bắt đầu *" styleClass="product-dialog-field-label"/>
                        <DatePicker fx:id="startDatePicker" maxWidth="Infinity" styleClass="product-dialog-input"/>
                    </VBox>

                    <VBox spacing="7" styleClass="product-dialog-field" GridPane.rowIndex="0" GridPane.columnIndex="1">
                        <Label text="Ngày kết thúc *" styleClass="product-dialog-field-label"/>
                        <DatePicker fx:id="endDatePicker" maxWidth="Infinity" styleClass="product-dialog-input"/>
                    </VBox>

                    <VBox spacing="7" styleClass="product-dialog-field" GridPane.rowIndex="1" GridPane.columnIndex="0">
                        <Label text="Giờ bắt đầu *" styleClass="product-dialog-field-label"/>
                        <TextField fx:id="startTimeField" promptText="HH:mm" styleClass="product-dialog-input"/>
                    </VBox>

                    <VBox spacing="7" styleClass="product-dialog-field" GridPane.rowIndex="1" GridPane.columnIndex="1">
                        <Label text="Giờ kết thúc *" styleClass="product-dialog-field-label"/>
                        <TextField fx:id="endTimeField" promptText="HH:mm" styleClass="product-dialog-input"/>
                    </VBox>
                </GridPane>
            </VBox>

            <VBox spacing="10" styleClass="product-dialog-section">
                <VBox spacing="7" styleClass="product-dialog-field">
                    <Label text="Bước giá tối thiểu ($) *" styleClass="product-dialog-field-label"/>
                    <TextField fx:id="minIncrementField" text="1" styleClass="product-dialog-input"/>
                </VBox>
            </VBox>
        </VBox>
    </VBox>
</ScrollPane>
