<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<HBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.auction.ui.view.AccountController"
      prefWidth="1040"
      prefHeight="660"
      style="-fx-background-color: #f3f6fb;">

    <!-- Sidebar -->
    <VBox prefWidth="230"
          spacing="22"
          style="-fx-background-color: #172033;">
        <padding>
            <Insets top="28" right="18" bottom="24" left="18"/>
        </padding>

        <VBox spacing="2">
            <Label text="ĐẤU GIÁ"
                   style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #8fb2ff;"/>
            <Label text="Bảng điều khiển"
                   style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: white;"/>
        </VBox>

        <VBox spacing="8">
            <Button text="Phiên đấu giá"
                    onAction="#handleBack"
                    maxWidth="Infinity"
                    alignment="CENTER_LEFT"
                    style="-fx-background-color: transparent; -fx-text-fill: #c7d0dd; -fx-padding: 11 14;"/>
            <Button fx:id="productsSidebarButton"
                    text="Kho hàng"
                    onAction="#handleSidebarProducts"
                    maxWidth="Infinity"
                    alignment="CENTER_LEFT"
                    style="-fx-background-color: transparent; -fx-text-fill: #c7d0dd; -fx-padding: 11 14;"/>
            <Button text="Tài khoản"
                    maxWidth="Infinity"
                    alignment="CENTER_LEFT"
                    style="-fx-background-color: #2d6cdf; -fx-background-radius: 6; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 11 14;"/>
        </VBox>

        <Region VBox.vgrow="ALWAYS"/>

        <VBox spacing="10">
            <VBox spacing="6"
                  style="-fx-background-color: #22304a; -fx-background-radius: 8; -fx-padding: 14;">
                <Label text="Tài khoản"
                       style="-fx-font-size: 12px; -fx-text-fill: #9aa8bd;"/>
                <Label fx:id="sidebarRoleLabel"
                       text="Role: --"
                       style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                <Label fx:id="sidebarBalanceLabel"
                       text="Ví: --"
                       style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: white;"/>
            </VBox>
        </VBox>
    </VBox>

    <!-- Main content -->
    <VBox spacing="18" HBox.hgrow="ALWAYS">
        <padding>
            <Insets top="28" right="34" bottom="28" left="34"/>
        </padding>

        <!-- Page header -->
        <VBox spacing="4">
            <Label text="Tài khoản"
                   style="-fx-font-size: 30px; -fx-font-weight: bold; -fx-text-fill: #172033;"/>
            <Label text="Quản lý thông tin, số dư và lịch sử đặt giá của bạn."
                   style="-fx-font-size: 13px; -fx-text-fill: #667085;"/>
        </VBox>

        <!-- Top row: Profile + Balance + Deposit/Withdraw -->
        <HBox spacing="14">

            <!-- Profile card -->
            <VBox spacing="8" HBox.hgrow="ALWAYS"
                  style="-fx-background-color: white; -fx-background-radius: 8; -fx-border-color: #e0e7f0; -fx-border-radius: 8; -fx-padding: 16;">
                <Label text="HỒ SƠ"
                       style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #7b8794;"/>
                <Label fx:id="usernameLabel"
                       text="--"
                       style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #172033;"/>
                <Label fx:id="roleLabel"
                       text="--"
                       style="-fx-font-size: 13px; -fx-text-fill: #667085;"/>
                <Label fx:id="userIdLabel"
                       text="--"
                       style="-fx-font-size: 11px; -fx-text-fill: #aab0bb;"/>
                <Button text="Đăng xuất"
                        onAction="#handleLogout"
                        maxWidth="Infinity"
                        alignment="CENTER"
                        style="-fx-background-color: #d92d20; -fx-background-radius: 6; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 9 14;"/>
            </VBox>

            <!-- Balance card -->
            <VBox spacing="8" HBox.hgrow="ALWAYS"
                  style="-fx-background-color: white; -fx-background-radius: 8; -fx-border-color: #e0e7f0; -fx-border-radius: 8; -fx-padding: 16;">
                <Label text="SỐ DƯ"
                       style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #7b8794;"/>
                <Label fx:id="balanceLabel"
                       text="--"
                       style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #2d6cdf;"/>
                <Label fx:id="balanceMessageLabel"
                       text="Số dư hiện tại"
                       style="-fx-font-size: 12px; -fx-text-fill: #667085;"/>
            </VBox>

            <!-- Deposit / Withdraw card -->
            <VBox spacing="10" HBox.hgrow="ALWAYS"
                  style="-fx-background-color: white; -fx-background-radius: 8; -fx-border-color: #e0e7f0; -fx-border-radius: 8; -fx-padding: 16;">
                <Label text="NẠP / RÚT TIỀN"
                       style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #7b8794;"/>
                <TextField fx:id="amountField"
                           promptText="Nhập số tiền..."
                           style="-fx-background-radius: 6; -fx-border-color: #d0d5dd; -fx-border-radius: 6; -fx-padding: 8 10;"/>
                <HBox spacing="8">
                    <Button text="Nạp tiền"
                            onAction="#handleDeposit"
                            HBox.hgrow="ALWAYS"
                            maxWidth="Infinity"
                            style="-fx-background-color: #12a594; -fx-background-radius: 6; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 9 0;"/>
                    <Button text="Rút tiền"
                            onAction="#handleWithdraw"
                            HBox.hgrow="ALWAYS"
                            maxWidth="Infinity"
                            style="-fx-background-color: #d92d20; -fx-background-radius: 6; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 9 0;"/>
                </HBox>
                <Label fx:id="actionMessageLabel"
                       text=""
                       style="-fx-font-size: 12px;"/>
            </VBox>

        </HBox>

        <!-- Bid history table -->
        <VBox fx:id="bidHistoryCard"
              spacing="14"
              VBox.vgrow="ALWAYS"
              style="-fx-background-color: white; -fx-background-radius: 10; -fx-border-color: #e0e7f0; -fx-border-radius: 10; -fx-padding: 18;">

            <HBox alignment="CENTER_LEFT" spacing="12">
                <VBox spacing="2">
                    <Label text="Lịch sử đặt giá"
                           style="-fx-font-size: 17px; -fx-font-weight: bold; -fx-text-fill: #172033;"/>
                    <Label text="Các lần đặt giá của bạn trong các phiên đấu giá."
                           style="-fx-font-size: 12px; -fx-text-fill: #667085;"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="messageLabel"
                       text=""
                       style="-fx-text-fill: #12a594; -fx-font-weight: bold; -fx-font-size: 13px;"/>
                <Button text="Làm mới"
                        onAction="#handleRefreshHistory"
                        style="-fx-background-color: white; -fx-border-color: #b8c2d6; -fx-border-radius: 6; -fx-background-radius: 6; -fx-text-fill: #344054; -fx-font-weight: bold; -fx-padding: 8 14;"/>
            </HBox>

            <TableView fx:id="bidHistoryTable" VBox.vgrow="ALWAYS"
                       style="-fx-background-color: white; -fx-border-color: #e4e7ec; -fx-border-radius: 6; -fx-background-radius: 6;">
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                </columnResizePolicy>
                <columns>
                    <TableColumn fx:id="colBidId"     text="Loại sản phẩm"/>
                    <TableColumn fx:id="colAuctionId" text="Tên sản phẩm"/>
                    <TableColumn fx:id="colBidAmount" text="Số tiền đặt"/>
                    <TableColumn fx:id="colBidTime"   text="Thời gian"/>
                </columns>
            </TableView>
        </VBox>

    </VBox>
</HBox>

