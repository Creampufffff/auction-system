<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<HBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.auction.client.controller.LiveBiddingController"
      prefWidth="1040" prefHeight="660"
      style="-fx-background-color: #f3f6fb;">

    <VBox prefWidth="240" spacing="22" style="-fx-background-color: #172033;">
        <padding><Insets top="28" right="18" bottom="24" left="18"/></padding>

        <VBox spacing="2">
            <Label text="ĐẤU GIÁ" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #8fb2ff;"/>
            <Label text="Live Room" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: white;"/>
        </VBox>

        <VBox spacing="8">
            <Button fx:id="backButton"
                    text="← Quay lại"
                    onAction="#handleBack"
                    maxWidth="Infinity"
                    alignment="CENTER_LEFT" />
        </VBox>

        <Region VBox.vgrow="ALWAYS"/>

        <VBox spacing="6" style="-fx-background-color: #22304a; -fx-background-radius: 8; -fx-padding: 14;">
            <Label text="Trạng thái" style="-fx-font-size: 12px; -fx-text-fill: #9aa8bd;"/>
            <Label text="Đang trực tiếp" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #00c853;"/>
        </VBox>
    </VBox>

    <VBox spacing="20" HBox.hgrow="ALWAYS">
        <padding><Insets top="28" right="34" bottom="28" left="34"/></padding>

        <HBox alignment="CENTER_LEFT">
            <VBox spacing="4">
                <Label fx:id="productNameLabel" text="Đang tải..." style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #172033;"/>
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="ID: #UET-2026" style="-fx-text-fill: #667085;"/>
                    <Label text="● LIVE" style="-fx-text-fill: #d92d20; -fx-font-weight: bold;"/>
                </HBox>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <VBox alignment="CENTER_RIGHT" spacing="5" style="-fx-background-color: #172033; -fx-padding: 10 20; -fx-background-radius: 10;">
                <Label text="THỜI GIAN CÒN LẠI" style="-fx-font-size: 10px; -fx-text-fill: #8fb2ff;"/>
                <Label fx:id="timerLabel" text="00:10:00" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: white; -fx-font-family: 'Monospaced';"/>
            </VBox>
        </HBox>

        <HBox spacing="20" VBox.vgrow="ALWAYS">
            <VBox spacing="20" prefWidth="380">
                <VBox spacing="15" style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 25; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 5);">
                    <VBox spacing="10" style="-fx-background-color: #172033; -fx-background-radius: 8; -fx-padding: 20;">
                        <Label text="GIÁ HIỆN TẠI" style="-fx-text-fill: #8fb2ff; -fx-font-size: 12px;"/>
                        <Label fx:id="currentPriceLabel" text="\$0.00" style="-fx-text-fill: white; -fx-font-size: 32px; -fx-font-weight: bold;"/>
                    </VBox>
                    <VBox spacing="8">
                        <Label text="Người dẫn đầu:" style="-fx-text-fill: #667085; -fx-font-size: 13px;"/>
                        <Label text="dang_thang_uet" style="-fx-font-weight: bold; -fx-font-size: 16px; -fx-text-fill: #172033;"/>
                    </VBox>
                </VBox>

                <VBox spacing="15" style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 20;">
                    <Label text="ĐẶT GIÁ CỦA BẠN" style="-fx-font-weight: bold; -fx-text-fill: #172033;"/>
                    <TextField fx:id="bidAmountField" promptText="Nhập mức giá..." style="-fx-padding: 12; -fx-background-radius: 8;"/>
                    <Button text="XÁC NHẬN ĐẶT GIÁ" onAction="#handlePlaceBid" maxWidth="Infinity"
                            style="-fx-background-color: #2d6cdf; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 12; -fx-background-radius: 8;"/>
                </VBox>
            </VBox>

            <VBox spacing="15" HBox.hgrow="ALWAYS" style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 20;">
                <Label text="LỊCH SỬ ĐẤU GIÁ" style="-fx-font-weight: bold; -fx-text-fill: #172033;"/>
                <ListView fx:id="bidHistoryList" VBox.vgrow="ALWAYS" style="-fx-background-radius: 8;"/>
            </VBox>
        </HBox>
    </VBox>
</HBox>