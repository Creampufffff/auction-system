<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.*?>

<HBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.auction.ui.view.LiveBiddingController"
      prefWidth="1040" prefHeight="660"
      style="-fx-background-color: #f3f6fb;">

    <VBox prefWidth="250" spacing="22" style="-fx-background-color: #172033;">
        <padding><Insets top="28" right="18" bottom="24" left="18"/></padding>

        <VBox spacing="2">
            <Label text="ĐẤU GIÁ" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #8fb2ff;"/>
            <Label text="Live Room" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: white;"/>
        </VBox>

        <VBox spacing="8">
            <Button fx:id="backButton"
                    text="← Quay lại"
                    onAction="#handleBack"
                    maxWidth="Infinity"
                    alignment="CENTER_LEFT" />
        </VBox>

        <Region VBox.vgrow="ALWAYS"/>

        <VBox spacing="6" style="-fx-background-color: #22304a; -fx-background-radius: 8; -fx-padding: 14;">
            <Label text="Ví của bạn" style="-fx-font-size: 12px; -fx-text-fill: #9aa8bd;"/>
            <Label fx:id="accountBalanceLabel" text="\$0.00" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: white;"/>
        </VBox>
    </VBox>

    <VBox spacing="20" HBox.hgrow="ALWAYS">
        <padding><Insets top="28" right="34" bottom="28" left="34"/></padding>

        <HBox alignment="CENTER_LEFT">
            <VBox spacing="4">
                <Label fx:id="productNameLabel" text="Đang tải..." style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #172033;"/>
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="ID: #UET-2026" style="-fx-text-fill: #667085;"/>
                    <Label text="● LIVE" style="-fx-text-fill: #d92d20; -fx-font-weight: bold;"/>
                </HBox>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <VBox alignment="CENTER_RIGHT" spacing="5" style="-fx-background-color: #172033; -fx-padding: 12 24; -fx-background-radius: 10;">
                <Label text="THỜI GIAN CÒN LẠI" style="-fx-font-size: 10px; -fx-text-fill: #8fb2ff;"/>
                <Label fx:id="timerLabel" text="00:00" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: white; -fx-font-family: 'Monospaced';"/>
            </VBox>
        </HBox>

        <HBox spacing="20" VBox.vgrow="ALWAYS">
            <VBox spacing="20" prefWidth="380">
                <VBox spacing="15" style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 25;">
                    <VBox spacing="10" style="-fx-background-color: #172033; -fx-background-radius: 8; -fx-padding: 20;">
                        <Label text="GIÁ HIỆN TẠI" style="-fx-text-fill: #8fb2ff; -fx-font-size: 12px;"/>
                        <VBox spacing="2">
                            <Label fx:id="currentPriceLabel" text="\$0.00" style="-fx-text-fill: white; -fx-font-size: 32px; -fx-font-weight: bold;"/>
                            <Label fx:id="priceChangeLabel" text="↑ $0.00 (0%) so với giá khởi điểm" style="-fx-text-fill: #4ade80; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                        </VBox>
                    </VBox>
                    <VBox spacing="8">
                        <Label text="Người dẫn đầu:" style="-fx-text-fill: #667085; -fx-font-size: 13px;"/>
                        <Label fx:id="leadingBidderLabel"
                               text="Chưa có"
                               style="-fx-font-weight: bold; -fx-font-size: 16px; -fx-text-fill: #172033;"/>
                    </VBox>
                </VBox>

                <VBox spacing="15" style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 20;">
                    <Label text="ĐẶT GIÁ CỦA BẠN" style="-fx-font-weight: bold; -fx-text-fill: #172033;"/>
                    <TextField fx:id="bidAmountField" promptText="Nhập mức giá..." style="-fx-padding: 12; -fx-background-radius: 8;"/>
                    <Button text="XÁC NHẬN ĐẶT GIÁ" onAction="#handlePlaceBid" maxWidth="Infinity"
                            style="-fx-background-color: #2d6cdf; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 12; -fx-background-radius: 8;"/>
                    <Separator style="-fx-opacity: 0.3;"/>
                    <Button fx:id="autoBidButton" text="🤖 ĐẶT GIÁ TỰ ĐỘNG (AUTO-BID)" onAction="#handleOpenAutoBiddingDialog" maxWidth="Infinity"
                            style="-fx-background-color: #7c3aed; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 12; -fx-background-radius: 8;"/>
                </VBox>
            </VBox>

            <VBox spacing="15" HBox.hgrow="ALWAYS" style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 20;">
                <HBox alignment="CENTER_LEFT">
                    <Label text="LỊCH SỬ ĐẤU GIÁ" style="-fx-font-weight: bold; -fx-text-fill: #172033;"/>
                </HBox>
                
                <VBox VBox.vgrow="ALWAYS" spacing="15" style="-fx-border-color: #e5e7eb; -fx-border-radius: 8; -fx-padding: 15;">
                    <HBox alignment="CENTER_LEFT">
                        <Label text="BIỂU ĐỒ DIỄN BIẾN GIÁ" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #6b7280;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <HBox spacing="5">
                            <Button fx:id="filter1dBtn" text="1D" onAction="#handleFilter1D" styleClass="chart-toggle-btn"/>
                            <Button fx:id="filter3dBtn" text="3D" onAction="#handleFilter3D" styleClass="chart-toggle-btn"/>
                            <Button fx:id="filter5dBtn" text="5D" onAction="#handleFilter5D" styleClass="chart-toggle-btn"/>
                            <Button fx:id="filter7dBtn" text="7D" onAction="#handleFilter7D" styleClass="chart-toggle-btn"/>
                            <Button fx:id="filterAllBtn" text="ALL" onAction="#handleFilterAll" styleClass="chart-toggle-btn-active"/>
                        </HBox>
                    </HBox>
                    
                    <StackPane fx:id="chartContainer" VBox.vgrow="ALWAYS" minHeight="250">
                        <LineChart fx:id="priceLineChart" animated="false" legendVisible="false">
                            <xAxis>
                                <CategoryAxis fx:id="xAxisLine" label="Thời gian" side="BOTTOM" animated="false"/>
                            </xAxis>
                            <yAxis>
                                <NumberAxis fx:id="yAxisLine" label="Giá (USD)" side="LEFT" animated="false"/>
                            </yAxis>
                        </LineChart>
                    </StackPane>
                </VBox>

                <VBox VBox.vgrow="ALWAYS" spacing="10" style="-fx-border-color: #e5e7eb; -fx-border-radius: 8; -fx-padding: 10;">
                    <Label text="LỊCH SỬ ĐẶT GIÁ" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #6b7280;"/>
                    <TableView fx:id="bidHistoryTable" VBox.vgrow="ALWAYS" styleClass="auction-table">
                        <columns>
                            <TableColumn fx:id="timeCol" text="THỜI GIAN" prefWidth="120" />
                            <TableColumn fx:id="userCol" text="NGƯỜI DÙNG" prefWidth="180" />
                            <TableColumn fx:id="priceCol" text="GIÁ ĐẶT (USD)" prefWidth="150" />
                            <TableColumn fx:id="changeCol" text="THAY ĐỔI" prefWidth="180" />
                        </columns>
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                        </columnResizePolicy>
                    </TableView>
                </VBox>
            </VBox>
        </HBox>
    </VBox>
</HBox>

