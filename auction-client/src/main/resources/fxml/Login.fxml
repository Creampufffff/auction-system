<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Text?>
<?import javafx.scene.image.*?>

<HBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.auction.client.controller.LoginController"
      prefWidth="800" prefHeight="600"
      style="-fx-background-color: white;">

    <VBox prefWidth="320" alignment="CENTER" spacing="20"
          style="-fx-background-color: #172033; -fx-padding: 40;">

        <ImageView fitWidth="100" preserveRatio="true">
            <image>
                <Image url="@../images/img.png" />
            </image>
        </ImageView>

        <Label text="UET AUCTION"
               style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: white;"/>

        <Text text="Chào mừng bạn quay trở lại với hệ thống đấu giá sinh viên VNU-UET."
              wrappingWidth="220" textAlignment="CENTER"
              style="-fx-fill: #8fb2ff; -fx-font-size: 14px;"/>

        <Region VBox.vgrow="ALWAYS"/>
        <Label text="© 2026 UET IT Student" style="-fx-text-fill: #5a6b89; -fx-font-size: 11px;"/>
    </VBox>

    <VBox HBox.hgrow="ALWAYS" alignment="CENTER_LEFT" spacing="25" style="-fx-padding: 0 80 0 80;">

        <VBox spacing="5">
            <Label text="Đăng nhập"
                   style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #172033;"/>
            <Label text="Vui lòng nhập thông tin để tiếp tục."
                   style="-fx-font-size: 14px; -fx-text-fill: #667085;"/>
        </VBox>

        <VBox spacing="18" maxWidth="350">
            <VBox spacing="8">
                <Label text="Tên đăng nhập" style="-fx-font-weight: bold; -fx-text-fill: #344054;"/>
                <TextField fx:id="usernameField" promptText="Nhập username của bạn"
                           style="-fx-padding: 12; -fx-background-radius: 8; -fx-border-color: #d0d5dd; -fx-border-radius: 8;"/>
            </VBox>

            <VBox spacing="8">
                <Label text="Mật khẩu" style="-fx-font-weight: bold; -fx-text-fill: #344054;"/>
                <PasswordField fx:id="passwordField" promptText="••••••••"
                               style="-fx-padding: 12; -fx-background-radius: 8; -fx-border-color: #d0d5dd; -fx-border-radius: 8;"/>
            </VBox>

            <Label fx:id="messageLabel" wrapText="true" style="-fx-font-size: 13px; -fx-text-fill: #e74c3c;"/>

            <VBox spacing="15">
                <Button fx:id="loginButton" text="Đăng nhập hệ thống" onAction="#handleLogin" maxWidth="Infinity"
                        style="-fx-background-color: #2d6cdf; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 14; -fx-background-radius: 8; -fx-cursor: hand;"/>

                <HBox alignment="CENTER" spacing="5">
                    <Label text="Bạn chưa có tài khoản?" style="-fx-text-fill: #667085;"/>
                    <Button text="Đăng ký ngay" onAction="#handleOpenRegister"
                            style="-fx-background-color: transparent; -fx-text-fill: #2d6cdf; -fx-font-weight: bold; -fx-padding: 0; -fx-cursor: hand;"/>
                </HBox>
            </VBox>
        </VBox>
    </VBox>
</HBox>