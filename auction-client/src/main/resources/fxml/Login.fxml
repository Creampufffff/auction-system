<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.auction.client.controller.LoginController"
      alignment="CENTER"
      spacing="15"
      prefWidth="400"
      prefHeight="500"
      style="-fx-background-color: #f5f5f5;">

    <padding>
        <Insets top="30" right="40" bottom="30" left="40"/>
    </padding>

    <Label text="Auction Login"
           style="-fx-font-size: 28px; -fx-font-weight: bold;"/>

    <Label text="Đăng nhập vào hệ thống đấu giá"
           style="-fx-font-size: 14px; -fx-text-fill: #666666;"/>

    <VBox spacing="8" maxWidth="280">
        <Label text="Username"/>
        <TextField fx:id="usernameField"
                   promptText="Nhập username"/>
    </VBox>

    <VBox spacing="8" maxWidth="280">
        <Label text="Password"/>
        <PasswordField fx:id="passwordField"
                       promptText="Nhập password"/>
    </VBox>

    <Button text="Login"
            fx:id="loginButton"
            onAction="#handleLogin"
            maxWidth="280"
            style="-fx-background-color: #2d6cdf; -fx-text-fill: white; -fx-font-weight: bold;"/>

    <Button text="Đăng ký tài khoản"
            onAction="#handleOpenRegister"
            maxWidth="280"
            style="-fx-background-color: transparent; -fx-text-fill: #2d6cdf; -fx-underline: true;"/>

    <Label fx:id="messageLabel"
           text=""
           style="-fx-text-fill: red;"/>

</VBox>