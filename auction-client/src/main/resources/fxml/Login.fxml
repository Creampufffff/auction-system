<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.image.*?> <VBox xmlns:fx="http://javafx.com/fxml"
                                      fx:controller="com.auction.client.controller.LoginController"
                                      alignment="CENTER"
                                      spacing="20"
                                      prefWidth="400"
                                      prefHeight="550"
                                      styleClass="login-container"> <padding>
    <Insets top="40" right="50" bottom="40" left="50"/>
</padding>

    <ImageView fitWidth="120" preserveRatio="true">
        <image>
            <Image url="@../images/img.png" />
        </image>
    </ImageView>

    <VBox alignment="CENTER" spacing="5">
        <Label text="UET Auction" styleClass="title-label"/>
        <Label text="Hệ thống đấu giá sinh viên" styleClass="subtitle-label"/>
    </VBox>

    <VBox spacing="10" maxWidth="300">
        <Label text="Tên đăng nhập" styleClass="field-label"/>
        <TextField fx:id="usernameField" promptText="Nhập username" styleClass="modern-input"/>
    </VBox>

    <VBox spacing="10" maxWidth="300">
        <Label text="Mật khẩu" styleClass="field-label"/>
        <PasswordField fx:id="passwordField" promptText="Nhập password" styleClass="modern-input"/>
    </VBox>

    <VBox spacing="15" alignment="CENTER" maxWidth="300">
        <Button text="ĐĂNG NHẬP" fx:id="loginButton" onAction="#handleLogin"
                maxWidth="Infinity" styleClass="primary-button"/>

        <Button text="Chưa có tài khoản? Đăng ký ngay" onAction="#handleOpenRegister"
                styleClass="link-button"/>
    </VBox>

    <Label fx:id="messageLabel" text="" styleClass="error-label"/>

</VBox>